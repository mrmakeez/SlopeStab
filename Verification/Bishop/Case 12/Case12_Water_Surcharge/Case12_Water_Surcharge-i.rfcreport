            <childSections>
              <rfc_section>
                <Title>Error Code Descriptions</Title>
                <sectionLevel>UnderlinedSection</sectionLevel>
                <hasImage>false</hasImage>
                <maximizeSize>false</maximizeSize>
                <alternateRowBackgroundColor>false</alternateRowBackgroundColor>
                <postPageBreak>false</postPageBreak>
                <ignoreIndent>false</ignoreIndent>
                <fontSizeOffset>0</fontSizeOffset>
                <borderStyle>None</borderStyle>
                <dataRows>
                  <row>
                    <rowType>DataRow</rowType>
                    <data>
                      <data_string>The following errors were encountered during the computation:</data_string>
                    </data>
                  </row>
                  <row>
                    <rowType>DataRow</rowType>
                    <data>
                      <data_string>-108 = Total driving moment or total driving force &lt; 0.1. This is to limit the calculation of extremely high safety factors if the driving force is very small (0.1 is an arbitrary number).</data_string>
                    </data>
                  </row>
                  <row>
                    <rowType>DataRow</rowType>
                    <data>
                      <data_string>-111 = Safety factor equation did not converge</data_string>
                    </data>
                  </row>
                  <row>
                    <rowType>DataRow</rowType>
                    <data>
                      <data_string>-112 = The coefficient M-Alpha = cos(alpha)(1+tan(alpha)tan(phi)/F) &lt; 0.2 for the final iteration of the safety factor calculation. This screens out some slip surfaces which may not be valid in the context of the analysis, in particular, deep seated slip surfaces with many high negative base angle slices in the passive zone.</data_string>
                    </data>
                  </row>
                </dataRows>
              </rfc_section>
            </childSections>
          </rfc_section>
        </childSections>
      </rfc_section>
